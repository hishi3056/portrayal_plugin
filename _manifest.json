{
  "manifest_version": 2,
  "id": "rc.portrayal_plugin",
  "version": "1.0.0",
  "name": "群友观测簿",
  "description": "基于 NapCat API 采集群聊消息，生成用户画像并注入 MaiSaka Planner/Replyer 作为低优先级回复参考。支持常规/阴阳画像、版本历史、六维雷达图、关系图谱、词云、WebUI 管理。",
  "author": {
    "name": "R.c.",
    "url": "https://github.com/hishi3056"
  },
  "license": "GPL-3.0",
  "urls": {
    "repository": "https://github.com/hishi3056/portrayal_plugin",
    "homepage": "https://github.com/hishi3056/portrayal_plugin",
    "documentation": "https://github.com/hishi3056/portrayal_plugin/blob/main/README.md",
    "issues": "https://github.com/hishi3056/portrayal_plugin/issues"
  },
  "host_application": {
    "min_version": "1.0.6",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "send",
    "llm",
    "message",
    "person",
    "chat",
    "render",
    "api",
    "maisaka",
    "database"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": ["zh-CN"]
  }
}
